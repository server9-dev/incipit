{
  "name": "incipit",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, local-first, provider-agnostic AI writing assistant",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @incipit/web dev",
    "dev:web": "pnpm --filter @incipit/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
