{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Incipit",
  "version": "0.1.3",
  "identifier": "dev.server9.incipit",
  "build": {
    "frontendDist": "../apps/web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm --filter @incipit/web build"
  },
  "app": {
    "windows": [
      {
        "title": "Incipit",
        "width": 1200,
        "height": 820,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
