# --- AI provider (provider-agnostic) ---
# ollama (default) | openai | anthropic | google
AI_PROVIDER=ollama
# Override the model id; defaults are per-provider.
# Ollama default is "gemma3-writer" = gemma3:12b w/ num_ctx 16384 baked in.
# Build it once: ollama create gemma3-writer -f models/gemma3-writer.Modelfile
# AI_MODEL=gemma3-writer

# Ollama (local, default). Uses its OpenAI-compatible endpoint.
OLLAMA_BASE_URL=http://localhost:11434/v1

# Embedding model for story-bible retrieval (semantic context for the AI).
# Defaults per provider: ollama=nomic-embed-text, openai=text-embedding-3-small,
# google=text-embedding-004, anthropic=none (falls back to name-matching).
# Pull once for the default: ollama pull nomic-embed-text
# EMBED_MODEL=nomic-embed-text

# Hosted providers (only needed if you switch AI_PROVIDER)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=          # optional: any OpenAI-compatible gateway
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# --- server ---
PORT=8787
DB_PATH=./data/incipit.sqlite
